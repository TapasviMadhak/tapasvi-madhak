      .then((data) => {
        if (data.status === 'ok') {
          // Get all posts (expandable as you write more)
          setBlogPosts(data.items);
        }
        setLoadingBlogs(false);
      })
      .catch((error) => {
        console.error('Error fetching Medium posts:', error);
        setLoadingBlogs(false);
      });
  }, []);

